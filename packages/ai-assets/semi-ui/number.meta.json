{
  "name": "Typography.Numeral",
  "title": "数字格式化",
  "icon": "data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjQiIGhlaWdodD0iMjQiIHZpZXdCb3g9IjAgMCAyNCAyNCIgZmlsbD0ibm9uZSIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48cGF0aCBkPSJNMTYgMkwyMCA2TDE2IDEwTTQgNkw4IDJMMTIgNk00IDEyTDggMTZMNCAyME0xMiAxMkwxNiAyMEwyMCAxNiIgc3Ryb2tlPSIjNEU1OTY2IiBzdHJva2Utd2lkdGg9IjIiLz48L3N2Zz4=",
  "description": "数字格式化组件，可自动格式化普通数字、百分比、字节大小、科学计数法等，支持精度、取整方式控制",
  "tags": [
    "数字",
    "数值",
    "格式化",
    "排版"
  ],
  "category": "展示组件",
  "version": "1.0.0",
  "author": "LiuHan",
  "visualConfig": {
    "thumbnail": "data:image/svg+xml;base64,",
    "preferredWidth": 200,
    "preferredHeight": 32,
    "resizable": true,
    "aspectRatio": "no"
  },
  "properties": [
    {
      "name": "children",
      "description": "显示的数字或文本内容",
      "label": "数字内容",
      "type": "string",
      "defaultValue": "123456"
    },
    {
      "name": "rule",
      "description": "数字解析格式化规则",
      "label": "格式化规则",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "普通文本", "value": "text" },
        { "label": "数字", "value": "numbers" },
        { "label": "字节(十进制)", "value": "bytes-decimal" },
        { "label": "字节(二进制)", "value": "bytes-binary" },
        { "label": "百分比", "value": "percentages" },
        { "label": "科学计数法", "value": "exponential" }
      ],
      "defaultValue": "text"
    },
    {
      "name": "precision",
      "description": "小数点后保留位数",
      "label": "小数精度",
      "control": "number",
      "type": "number",
      "defaultValue": 0
    },
    {
      "name": "truncate",
      "description": "小数取整方式",
      "label": "取整方式",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "四舍五入", "value": "round" },
        { "label": "向上取整", "value": "ceil" },
        { "label": "向下取整", "value": "floor" }
      ],
      "defaultValue": "round"
    },
    {
      "name": "code",
      "description": "是否以代码样式展示",
      "label": "代码样式",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "copyable",
      "description": "是否允许点击复制",
      "label": "可复制",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "delete",
      "description": "是否显示删除线",
      "label": "删除线",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "disabled",
      "description": "是否禁用置灰",
      "label": "禁用",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "ellipsis",
      "description": "内容超长自动省略",
      "label": "自动省略",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "link",
      "description": "是否为链接样式",
      "label": "链接样式",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "mark",
      "description": "是否高亮标记",
      "label": "高亮标记",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "size",
      "description": "文本大小",
      "label": "大小",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "标准", "value": "normal" },
        { "label": "小", "value": "small" }
      ],
      "defaultValue": "normal"
    },
    {
      "name": "strong",
      "description": "是否加粗",
      "label": "加粗",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    },
    {
      "name": "type",
      "description": "文本颜色类型",
      "label": "颜色类型",
      "control": "select",
      "type": "string",
      "options": [
        { "label": "主要", "value": "primary" },
        { "label": "次要", "value": "secondary" },
        { "label": "三级", "value": "tertiary" },
        { "label": "四级", "value": "quaternary" },
        { "label": "警告", "value": "warning" },
        { "label": "危险", "value": "danger" },
        { "label": "成功", "value": "success" }
      ],
      "defaultValue": "primary"
    },
    {
      "name": "underline",
      "description": "是否显示下划线",
      "label": "下划线",
      "control": "boolean",
      "type": "boolean",
      "defaultValue": false
    }
  ],
  "events": []
}